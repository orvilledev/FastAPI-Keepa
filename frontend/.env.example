# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Backend API Configuration
# API origin only (no /api/v1 suffix). Production: https://keepa-api.onrender.com
# (metro-api.onrender.com is deprecated and does not include Feedback routes.)
VITE_API_URL=http://localhost:8000

# Optional: public HTTPS URL to the Windows desktop app installer (.exe). The navbar also reads the API
# GET /api/v1/public/client-config (set DESKTOP_APP_DOWNLOAD_URL on the backend) and prefers that value.
# VITE_DESKTOP_APP_DOWNLOAD_URL=https://your-cdn.example.com/releases/MSW-Overwatch-Setup-1.0.0.exe

# Optional: comma-separated emails that skip TOTP MFA (password-only). Electron builds also
# include a built-in warehouse fallback when client-config cannot be fetched from file://.
# VITE_MFA_EXEMPT_EMAILS=warehouse1@metroshoewarehouse.com,hello@warehouserepublic.com

# Local Vite only: skip login/MFA for UI testing. Defaults to on in `npm run dev`.
# Set to false to exercise the real auth flow locally.
# VITE_DEV_BYPASS_AUTH=true

# Off-price Analytics (sidebar → Analytics) is web-only and limited to:
# remote@metroshoewarehouse.com, stephanie@metroshoewarehouse.com,
# sunshine@metroshoewarehouse.com, orvillebarba@gmail.com.
# Hidden from Electron and other users.
# Backend: apply create_off_price_analytics_*.sql migrations in Supabase for persistence.
#
# Demo data is the default until 2026-08-01 00:00 America/Chicago, then live Daily Run
# archives take over. Preview live early: open /analytics?source=live
# (optional force demo before cutover: /analytics?source=demo).
