# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Backend API Configuration
VITE_API_URL=http://localhost:8000

# Optional: public HTTPS URL to the Windows desktop app installer (.exe). The navbar also reads the API
# GET /api/v1/public/client-config (set DESKTOP_APP_DOWNLOAD_URL on the backend) and prefers that value.
# VITE_DESKTOP_APP_DOWNLOAD_URL=https://your-cdn.example.com/releases/MSW-Overwatch-Setup-1.0.0.exe
