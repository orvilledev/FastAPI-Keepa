# Keepa API Configuration
KEEPA_API_KEY=your_keepa_api_key_here
KEEPA_API_KEYS=key1,key2,key3
KEEPA_API_URL=https://api.keepa.com/
KEEPA_OFFERS_LIMIT=50
KEEPA_RATE_LIMIT_DELAY_SECONDS=0.8
KEEPA_MIN_RATE_LIMIT_DELAY_SECONDS=0.15
KEEPA_DELAY_OFFERS_REFERENCE=50
KEEPA_MAX_RETRIES=3
KEEPA_RETRY_DELAY_SECONDS=2.0

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# Email Configuration (SMTP)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_FROM=your-email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_TO=recipient1@example.com, recipient2@example.com

# Application Environment
ENVIRONMENT=development
API_V1_STR=/api/v1

# Optional: public HTTPS URL to the Windows desktop installer (.exe). Exposed as
# GET /api/v1/public/client-config for the frontend navbar (no frontend rebuild).
# DESKTOP_APP_DOWNLOAD_URL=https://your-cdn.example.com/releases/MSW-Overwatch-Setup-1.0.0.exe

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Scheduler Configuration (24-hour format)
SCHEDULER_HOUR=2
SCHEDULER_MINUTE=0

# Maintenance mode controls
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=App is currently under maintenance. Please try again later.
# MAINTENANCE_ALLOWLIST_EMAILS=admin@example.com

# Comma-separated emails that skip TOTP MFA (password-only sign-in for shared stations).
# MFA_EXEMPT_EMAILS=warehouse1@metroshoewarehouse.com

# Off-price Excel report: comma-separated substrings; sellers whose display name
# matches (case/spacing/punctuation ignored) are omitted. Default metroshoe.
# Disable filtering: REPORT_EXCLUDED_SELLER_SUBSTRINGS=
# REPORT_EXCLUDED_SELLER_SUBSTRINGS=metroshoe,anotherbrand

# Sentry Error Tracking (optional - leave empty to disable)
SENTRY_DSN=
SENTRY_RELEASE=1.0.0
